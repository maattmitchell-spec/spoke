{
  "expo": {
    "name": "Spoke",
    "slug": "spoke",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spoke",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F08"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.spokecommunity.spoke",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Spoke uses your location to show nearby adventures and events.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Spoke uses your location to show nearby adventures and events.",
        "NSPhotoLibraryUsageDescription": "Spoke uses your photo library to let you update your profile picture.",
        "NSCameraUsageDescription": "Spoke uses your camera to let you upload a profile photo.",
        "NSAppleMusicUsageDescription": "Spoke does not access Apple Music.",
        "UIBackgroundModes": []
      },
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          }
        ]
      }
    },
    "android": {
      "package": "app.spokecommunity.spoke"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Spoke uses your location to show nearby adventures.",
          "locationAlwaysAndWhenInUsePermission": "Spoke uses your location to show nearby adventures."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Spoke uses your photo library to update your profile picture.",
          "cameraPermission": "Spoke uses your camera to upload a profile photo."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
